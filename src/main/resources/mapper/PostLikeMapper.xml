<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.seig.vibemusic.mapper.PostLikeMapper">

    <!-- 检查用户是否已点赞 -->
    <select id="checkUserLike" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM tb_post_like
        WHERE post_id = #{postId} AND user_id = #{userId}
    </select>

    <!-- 获取帖子点赞数 -->
    <select id="getPostLikeCount" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM tb_post_like
        WHERE post_id = #{postId}
    </select>

</mapper>
